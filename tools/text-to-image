# Sanitize token for logging
sanitize_token() {
  local token="$1"
  if [[ -z "$token" ]]; then
    echo "unset"
  else
    echo "${token:0:8}…****"
  fi
}

# Extract human-readable error message from provider JSON error response
# Tries common patterns across all providers:
#   OpenAI:      {"error": {"message": "...", "type": "...", "code": "..."}}
#   Stability:   {"message": "...", "name": "..."}
#   Google:      {"error": {"message": "...", "status": "...", "code": ...}}
#   HuggingFace: {"error": "..."} or {"error": {"message": "..."}}
#   BFL:         {"detail": "..."} or {"error": "..."}
#   Replicate:   {"detail": "..."}
#   SiliconFlow:  {"message": "...", "code": ...}
extract_api_error() {
  local response="$1"
  local msg=""
  msg="$(_jq -r '.error.message // .message // .detail // .error // empty' <<< "$response" 2>/dev/null)" || true
  if [[ -n "$msg" && "$msg" != "null" ]]; then
    printf '%s' "$msg"
  else
    printf '%s' "${response:0:200}"
  fi
}

# Shell-escape a value for safe eval
shell_escape() {
    printf '%q' "$1"
}

# Return the native output format for a given provider+model combination.
# This is the format the API returns without any conversion.
# Usage: get_native_format <provider> <model>
# Prints: png, jpg, or webp (defaults to png for unknown models)
get_native_format() {
  local provider="$1"
  local model="$2"
  local key="${provider}::${model}"

  case "$key" in
    openai::dall-e-3)                                     printf 'png' ;;
    openai::dall-e-2)                                     printf 'png' ;;
    stability::stable-diffusion-xl-1024-v1-0)             printf 'png' ;;
    google::imagen-4.0-generate-001)                      printf 'png' ;;
    google::imagen-4.0-ultra-generate-001)                printf 'png' ;;
    google::imagen-4.0-fast-generate-001)                 printf 'png' ;;
    google::imagen-3.0-generate-001)                      printf 'png' ;;
    huggingface::stabilityai/stable-diffusion-2-1)        printf 'png' ;;
    huggingface::runwayml/stable-diffusion-v1-5)          printf 'png' ;;
    huggingface::black-forest-labs/flux-1.1-pro)          printf 'webp' ;;
    bfl::flux-1.1-pro)                                    printf 'jpg' ;;
    bfl::flux-1.0-pro)                                    printf 'jpg' ;;
    replicate::stability-ai/sdxl:39ed52f*)                printf 'png' ;;
    replicate::black-forest-labs/flux-1.1-pro)            printf 'webp' ;;
    siliconflow::stabilityai/stable-diffusion-3-medium)   printf 'png' ;;
    siliconflow::stabilityai/stable-diffusion-xl-1.0)     printf 'png' ;;
    *)                                                    printf 'png' ;;
  esac
}

# Check whether an output path has a recognized image file extension.
# Returns 0 (true) if the basename contains a dot followed by a known image format,
# 1 (false) otherwise. Handles edge cases: dots in directory paths, trailing dots,
# and unrecognized extensions (e.g., .txt).
# Usage: has_recognized_image_extension <output_path>
has_recognized_image_extension() {
  local output_path="$1"
  local output_basename
  output_basename="$(basename "$output_path")"

  # No dot in basename → no extension
  if [[ "$output_basename" != *.* ]]; then
    return 1
  fi

  local ext="${output_basename##*.}"

  # Trailing dot (empty extension) → no recognized extension
  if [[ -z "$ext" ]]; then
    return 1
  fi

  case "${ext,,}" in
    png|jpg|jpeg|webp|avif|tiff|tif) return 0 ;;
    *) return 1 ;;
  esac
}

# Resolve the output path by appending a native format extension when the user
# did not specify a recognized image extension. Uses provider+model to determine
# the native format; falls back to png if no provider can be resolved.
# Prints the (possibly updated) output path to stdout.
# Usage: resolve_output_extension <output> <provider> <model> <quality>
resolve_output_extension() {
  local output="$1"
  local provider="${2:-}"
  local model="${3:-}"
  local quality="${4:-high}"

  if [[ -z "$output" ]]; then
    printf '%s' "$output"
    return 0
  fi

  if has_recognized_image_extension "$output"; then
    printf '%s' "$output"
    return 0
  fi

  # No recognized extension — resolve native format
  local resolved_provider="${provider}"
  local resolved_model="${model}"
  if [[ -z "$resolved_provider" ]]; then
    resolved_provider="$(select_provider "$quality" 2>/dev/null)" || true
  fi
  if [[ -n "$resolved_provider" && -z "$resolved_model" ]]; then
    resolved_model="$(get_provider_model "$resolved_provider")"
  fi
  if [[ -n "$resolved_provider" ]]; then
    local native_ext
    native_ext="$(get_native_format "$resolved_provider" "$resolved_model")"
    log_info "No output format specified, using native format: ${native_ext}"
    printf '%s' "${output}.${native_ext}"
  else
    log_info "No output format specified, defaulting to png"
    printf '%s' "${output}.png"
  fi
}

# Determine the best available conversion command for a source→target format pair.
# Prints the command name to use, or empty string if no tool is available.
# Prefers specialized tools (cwebp, avifenc) over ImageMagick for quality and speed.
# Usage: get_conversion_command <source_format> <target_format>
get_conversion_command() {
  local source_format="$1"
  local target_format="$2"

  # No conversion needed if formats match
  if [[ "$source_format" == "$target_format" ]]; then
    printf ''
    return 0
  fi

  case "$target_format" in
    webp)
      if command -v cwebp >/dev/null 2>&1; then
        printf 'cwebp'
      elif command -v magick >/dev/null 2>&1; then
        printf 'magick'
      elif command -v convert >/dev/null 2>&1; then
        printf 'convert'
      fi
      ;;
    avif)
      if command -v avifenc >/dev/null 2>&1; then
        printf 'avifenc'
      elif command -v magick >/dev/null 2>&1; then
        printf 'magick'
      elif command -v convert >/dev/null 2>&1; then
        printf 'convert'
      fi
      ;;
    png|jpg)
      if command -v magick >/dev/null 2>&1; then
        printf 'magick'
      elif command -v convert >/dev/null 2>&1; then
        printf 'convert'
      fi
      ;;
  esac
}

# Ensure the output file's actual image format matches the requested extension.
# Detects format via file(1) and converts using the best available tool.
# Prefers specialized converters (cwebp for WebP, avifenc for AVIF) over ImageMagick.
# Gracefully degrades (warning only) when no conversion tool is installed.
ensure_output_format() {
  local output_path="$1"

  # Extract requested extension (lowercase)
  local requested_ext
  requested_ext="${output_path##*.}"
  requested_ext="${requested_ext,,}"

  # Normalize jpeg -> jpg for comparison
  local requested_normalized="$requested_ext"
  [[ "$requested_normalized" == "jpeg" ]] && requested_normalized="jpg"

  # Only handle supported formats
  case "$requested_normalized" in
    png|jpg|webp|avif) ;;
    *)
      log_debug "ensure_output_format: unsupported target format '$requested_ext', skipping conversion"
      return 0
      ;;
  esac

  # Detect actual format via file(1)
  local actual_mime
  actual_mime="$(file --mime-type -b "$output_path" 2>/dev/null)" || {
    log_debug "ensure_output_format: file(1) failed, skipping format check"
    return 0
  }

  # Map mime type to normalized extension
  local actual_normalized
  case "$actual_mime" in
    image/png)  actual_normalized="png" ;;
    image/jpeg) actual_normalized="jpg" ;;
    image/webp) actual_normalized="webp" ;;
    image/avif) actual_normalized="avif" ;;
    *)
      log_debug "ensure_output_format: unknown mime type '$actual_mime', skipping conversion"
      return 0
      ;;
  esac

  # If formats match, nothing to do
  if [[ "$actual_normalized" == "$requested_normalized" ]]; then
    log_debug "ensure_output_format: format matches ($actual_normalized), no conversion needed"
    return 0
  fi

  log_debug "ensure_output_format: format mismatch detected — file is $actual_mime ($actual_normalized) but extension is .$requested_ext ($requested_normalized)"

  # Find the best conversion tool for this format pair
  local converter
  converter="$(get_conversion_command "$actual_normalized" "$requested_normalized")"

  if [[ -z "$converter" ]]; then
    log_warn "Downloaded image is actually $actual_normalized but output file has .$requested_ext extension. Install a conversion tool to enable automatic format conversion."
    return 0
  fi

  # Convert using the best available tool
  local tmp_converted
  tmp_converted="$(mktemp "${output_path}.convert.XXXXXX.${requested_ext}")"

  local convert_ok=false
  case "$converter" in
    cwebp)
      if cwebp -q 90 "$output_path" -o "$tmp_converted" >/dev/null 2>&1; then
        convert_ok=true
      fi
      ;;
    avifenc)
      if avifenc --min 20 --max 30 "$output_path" "$tmp_converted" >/dev/null 2>&1; then
        convert_ok=true
      fi
      ;;
    magick|convert)
      if "$converter" "$output_path" "$tmp_converted" 2>/dev/null; then
        convert_ok=true
      fi
      ;;
  esac

  if [[ "$convert_ok" == "true" ]]; then
    mv -f "$tmp_converted" "$output_path"
    log_debug "ensure_output_format: converted $actual_normalized -> $requested_normalized via $converter successfully"
    return 0
  else
    rm -f "$tmp_converted"
    log_warn "ensure_output_format: conversion from $actual_normalized to $requested_normalized via $converter failed"
    return 1
  fi
}

# Truncate long string values in a JSON response for YAML sidecar readability.
# Replaces any string field longer than max_field_len with a placeholder.
# Falls back to simple character truncation if jq is unavailable.
# Usage: truncate_response_for_yaml <response_json>
truncate_response_for_yaml() {
  local response="$1"
  local max_field_len=200

  # Try jq-based field truncation
  if command -v jq >/dev/null 2>&1; then
    local result
    result="$(_jq 'walk(if type == "string" and (length > '"$max_field_len"') then "[\(length) chars truncated]" else . end)' <<< "$response" 2>/dev/null)"
    if [[ -n "$result" ]]; then
      printf '%s' "$result"
      return 0
    fi
  fi

  # Fallback: simple character truncation
  if [[ ${#response} -gt 5000 ]]; then
    printf '%s' "${response:0:2000}...[TRUNCATED: ${#response} chars total]"
  else
    printf '%s' "$response"
  fi
}

# Sanitize a JSON response body for YAML sidecar output.
# Keeps all text/metadata fields verbatim (no truncation).
# Only replaces fields that look like base64 image data (>1000 chars of base64
# characters) with a size placeholder.
# Redacts any fields named *token*, *key*, *secret*, *authorization* as
# defense-in-depth against accidental credential leakage.
# Falls back to regex-based sanitization if jq is unavailable.
# Usage: sanitize_response_for_yaml <response_json>
sanitize_response_for_yaml() {
  local response="$1"

  if [[ -z "$response" ]]; then
    printf '%s' "$response"
    return 0
  fi

  # Try jq-based sanitization
  if command -v jq >/dev/null 2>&1; then
    local result
    result="$(_jq '
      walk(
        if type == "object" then
          with_entries(
            if (.key | test("token|key|secret|authorization|password"; "i")) then
              .value = "[REDACTED]"
            elif (.value | type) == "string" and (.value | length) > 1000 and (.value | test("^[A-Za-z0-9+/=\\s]+$")) then
              .value = "[base64 image data: \(.value | length) chars]"
            else .
            end
          )
        elif type == "string" and length > 1000 and test("^[A-Za-z0-9+/=\\s]+$") then
          "[base64 image data: \(length) chars]"
        else .
        end
      )
    ' <<< "$response" 2>/dev/null)"
    if [[ -n "$result" ]]; then
      printf '%s' "$result"
      return 0
    fi
  fi

  # Fallback: simple regex-based sanitization
  # Replace long base64-like strings (>1000 chars of [A-Za-z0-9+/=])
  local sanitized="$response"
  if [[ ${#sanitized} -gt 5000 ]]; then
    printf '%s' "${sanitized:0:2000}...[TRUNCATED: ${#sanitized} chars total]"
  else
    printf '%s' "$sanitized"
  fi
}

# Sanitize a JSON request body for YAML sidecar output.
# Pretty-prints the JSON and redacts any fields whose names match sensitive
# patterns (*token*, *key*, *secret*, *authorization*, *password*) as
# defense-in-depth. Auth credentials are normally in HTTP headers, not in
# request payloads, but this provides an extra safety net.
# Usage: sanitize_request_for_yaml <request_json>
sanitize_request_for_yaml() {
  local request="$1"

  if [[ -z "$request" ]]; then
    printf '%s' "$request"
    return 0
  fi

  # Try jq-based redaction
  if command -v jq >/dev/null 2>&1; then
    local result
    result="$(_jq '
      walk(
        if type == "object" then
          with_entries(
            if (.key | test("token|key|secret|authorization|password"; "i")) then
              .value = "[REDACTED]"
            else .
            end
          )
        else .
        end
      )
    ' <<< "$request" 2>/dev/null)"
    if [[ -n "$result" ]]; then
      printf '%s' "$result"
      return 0
    fi
  fi

  # Fallback: pass through as-is (payloads normally don't contain credentials)
  printf '%s' "$request"
}

# Write generation metadata YAML sidecar file alongside the output image.
# Uses global vars set by the provider function: _GEN_API_URL, _GEN_API_METHOD,
# _GEN_API_REQUEST, _GEN_API_RESPONSE, _GEN_HTTP_CODE, _GEN_EXTRA_INFO
# Arguments: output_path prompt negative_prompt width height quality provider model duration_ms [exit_code]
write_generation_info() {
  local output_path="$1"
  local prompt="$2"
  local negative_prompt="$3"
  local width="$4"
  local height="$5"
  local quality="$6"
  local provider="$7"
  local model="$8"
  local duration_ms="$9"
  local exit_code="${10:-0}"

  local yaml_path="${output_path%.*}.yaml"
  local timestamp
  timestamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

  # Determine status and error message
  local gen_status="success"
  local error_message=""
  if (( exit_code != 0 )); then
    gen_status="error"
    # Extract error message from API response if available
    if [[ -n "$_GEN_API_RESPONSE" ]]; then
      error_message="$(extract_api_error "$_GEN_API_RESPONSE" 2>/dev/null)" || true
    fi
    if [[ -z "$error_message" ]]; then
      error_message="Generation failed with exit code ${exit_code}"
    fi
  fi

  # Image metadata
  local file_size_bytes=0
  local file_size_human="unknown"
  local format_detected="unknown"
  local img_width="unknown"
  local img_height="unknown"

  if [[ -f "$output_path" ]]; then
    file_size_bytes="$(stat --format='%s' "$output_path" 2>/dev/null || stat -f '%z' "$output_path" 2>/dev/null || printf '0')"
    if [[ "$file_size_bytes" -ge 1048576 ]]; then
      file_size_human="$(awk "BEGIN {printf \"%.1f MB\", ${file_size_bytes}/1048576}")"
    elif [[ "$file_size_bytes" -ge 1024 ]]; then
      file_size_human="$(( file_size_bytes / 1024 )) KB"
    else
      file_size_human="${file_size_bytes} B"
    fi
    format_detected="$(file --mime-type -b "$output_path" 2>/dev/null || printf 'unknown')"
    # Try to get dimensions via identify (ImageMagick) or file
    if command -v identify >/dev/null 2>&1; then
      local dims
      dims="$(identify -format '%wx%h' "$output_path" 2>/dev/null || true)"
      if [[ "$dims" =~ ^([0-9]+)x([0-9]+)$ ]]; then
        img_width="${BASH_REMATCH[1]}"
        img_height="${BASH_REMATCH[2]}"
      fi
    fi
  fi

  # Sanitize request for YAML (indent for literal block)
  local request_indented=""
  if [[ -n "$_GEN_API_REQUEST" ]]; then
    local request_clean
    request_clean="$(sanitize_request_for_yaml "$_GEN_API_REQUEST")"
    request_indented="$(_jq '.' <<< "$request_clean" 2>/dev/null | sed 's/^/    /' || printf '%s' "$request_clean" | sed 's/^/    /')"
  fi

  # Sanitize response for YAML (indent for literal block)
  local response_indented=""
  if [[ -n "$_GEN_API_RESPONSE" ]]; then
    local response_clean
    response_clean="$(sanitize_response_for_yaml "$_GEN_API_RESPONSE")"
    response_indented="$(_jq '.' <<< "$response_clean" 2>/dev/null | sed 's/^/    /' || printf '%s' "$response_clean" | sed 's/^/    /')"
  fi

  # Determine content-type header based on request method
  local content_type_header="application/json"

  # HTTP code from global (set by retry_curl)
  local http_code="${_GEN_HTTP_CODE:-}"

  # Get native format for this model
  local native_fmt
  native_fmt="$(get_native_format "$provider" "$model")"

  # Build provider_details section
  local provider_details_section=""
  if [[ -n "$_GEN_EXTRA_INFO" ]]; then
    local old_ifs="$IFS"
    IFS=$'\n'
    local pair
    for pair in $_GEN_EXTRA_INFO; do
      local key="${pair%%=*}"
      local value="${pair#*=}"
      provider_details_section+="$(printf '  %s: "%s"\n' "$key" "$value")"
    done
    IFS="$old_ifs"
  else
    provider_details_section="  {}"
  fi

  # Write YAML
  cat > "$yaml_path" <<YAML
# Image Generation Details
# Generated by ${APP_NAME} v${APP_VERSION}
# ${timestamp}

generation:
  timestamp: "${timestamp}"
  tool_version: "${APP_VERSION}"
  duration_ms: ${duration_ms}
  status: "${gen_status}"
  error_message: "$(printf '%s' "${error_message}")"

input:
  prompt: |
$(printf '%s' "$prompt" | sed 's/^/    /')
  negative_prompt: "$(printf '%s' "${negative_prompt}")"
  provider: "${provider}"
  model: "${model}"
  width: ${width}
  height: ${height}
  quality: "${quality}"
  native_format: "${native_fmt}"

request:
  url: "${_GEN_API_URL}"
  method: "${_GEN_API_METHOD}"
  headers:
    content_type: "${content_type_header}"
  payload: |
${request_indented}

response:
  http_code: ${http_code:-0}
  body: |
${response_indented}

provider_details:
${provider_details_section}

output:
  file_path: "${output_path}"
  file_size_bytes: ${file_size_bytes}
  file_size_human: "${file_size_human}"
  format_detected: "${format_detected}"
  format_requested: "${output_path##*.}"
  width_px: ${img_width}
  height_px: ${img_height}
YAML

  log_debug "Generation info written to ${yaml_path}"
}

# Retry curl with exponential backoff
retry_curl() {
  local max_retries=3
  local attempt=0
  local delay=1
  local response
  local stderr_file
  stderr_file="$(mktemp)"

  while (( attempt < max_retries )); do
    # Capture response body and HTTP code
    response="$(_curl -s -w "\n%{http_code}" "$@" 2>"$stderr_file")"
    local http_code="${response##*$'\n'}"
    response="${response%$'\n'*}"

    # Handle malformed responses: default to 200 if http_code is not numeric
    if [[ ! "$http_code" =~ ^[0-9]+$ ]]; then
      http_code=200
    fi
    if [[ "${VERBOSE}" == "true" ]]; then
      local curl_stderr
      curl_stderr="$(cat "$stderr_file")"
      if [[ -n "$curl_stderr" ]]; then
        log_debug "Curl stderr: $curl_stderr" >&2
      fi
    fi

    if (( http_code >= 200 && http_code < 300 )); then
      rm -f "$stderr_file"
      _GEN_HTTP_CODE="$http_code"
      echo "$response"
      return 0
    fi

    if (( http_code == 429 )); then
      # Rate limited, wait for Retry-After or default
      local retry_after
      retry_after="$(_curl -s -I "$@" 2>/dev/null | grep -i retry-after | sed 's/.*: //' | tr -d '\r')"
      if [[ -n "$retry_after" ]] && [[ "$retry_after" =~ ^[0-9]+$ ]]; then
        delay="$retry_after"
      fi
      log_warn "Rate limited (429), retrying in $delay seconds" >&2
    elif (( http_code >= 500 )); then
      log_warn "Server error ($http_code), retrying in $delay seconds (attempt $((attempt+1))/$max_retries)" >&2
    else
      log_err "Request failed with HTTP $http_code"
      log_debug "Response body: ${response:0:500}" >&2
      rm -f "$stderr_file"
      _GEN_HTTP_CODE="$http_code"
      echo "$response"
      return "$EXIT_NETWORK_ERROR"
    fi

    sleep "$delay"
    (( delay *= 2 ))
    (( attempt++ ))
  done

  rm -f "$stderr_file"
  _GEN_HTTP_CODE="$http_code"
  log_err "Max retries exceeded"
  return "$EXIT_NETWORK_ERROR"
}

# Custom timeout wrapper to handle subshell issues
timeout_wrapper() {
  local timeout_seconds="$1"
  shift
  local pid

  # Run in background
  "$@" &
  pid=$!

  # Wait with timeout
  local count=0
  while (( count < timeout_seconds )) && kill -0 "$pid" 2>/dev/null; do
    sleep 1
    (( count++ ))
  done

  if kill -0 "$pid" 2>/dev/null; then
    # Still running, kill it
    kill "$pid" 2>/dev/null
    wait "$pid" 2>/dev/null || true
    return 124  # Timeout exit code like GNU timeout
  else
    # Already finished, get exit code
    wait "$pid"
    return $?
  fi
}

