    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "Stability API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  local base64
  base64="$(_jq -r '.artifacts[0].base64 // empty' <<< "$response" 2>/dev/null)"
  if [[ -z "$base64" ]]; then
    _GEN_API_URL="https://api.stability.ai/v1/generation/$model/text-to-image"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    log_err "No base64 in Stability response"
    return "$EXIT_SERVER_ERROR"
  fi

  if ! base64 -d <<< "$base64" > "$output_path" 2>/dev/null; then
    _GEN_API_URL="https://api.stability.ai/v1/generation/$model/text-to-image"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    log_err "Failed to decode base64"
    return "$EXIT_GENERAL_ERROR"
  fi

  # Capture metadata for generation info sidecar
  _GEN_API_URL="https://api.stability.ai/v1/generation/$model/text-to-image"
  _GEN_API_REQUEST="$payload"
  _GEN_API_RESPONSE="$response"

  log_info "Image generated with Stability AI ($model)"
  return "$EXIT_SUCCESS"
}

