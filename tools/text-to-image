  fi
  if [[ -z "$api_key" ]]; then
    log_debug "HF API key not set"
    return "$EXIT_AUTH_FAILED"
  fi

  local payload
  payload="$(_jq -n --arg inputs "$prompt" '{inputs: $inputs, options: {wait_for_model: true}}' 2>/dev/null)"

  local response
  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would call: curl -s -X POST https://api-inference.huggingface.co/models/$model -H Authorization: Bearer $(sanitize_token "$api_key") -H Content-Type: application/json -d '$payload'"
    return "$EXIT_SUCCESS"
  fi
  response="$(retry_curl --max-time 60 -s -X POST "https://api-inference.huggingface.co/models/$model" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>/dev/null)"

  local exit_code=$?
  if (( exit_code != 0 )); then
    _GEN_API_URL="https://api-inference.huggingface.co/models/$model"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "HF API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  # Assume response is base64 or handle accordingly
  if [[ "$response" =~ ^[A-Za-z0-9+/]*={0,2}$ ]]; then
    # Base64
