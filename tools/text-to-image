parse_args() {
  while (($#)); do
    case "$1" in
      -h|--help) show_help; exit 0 ;;
      -V|--version) show_version; exit 0 ;;
      -n|--dry-run) DRY_RUN=true ;;
      -v|--verbose) VERBOSE=true ;;
      --prompt) shift; PROMPT="${1:-}" ;;
      --output) shift; OUTPUT="${1:-}" ;;
      --quality) shift; QUALITY="${1:-high}" ;;
      --config|--batch) shift; CONFIG_FILE="${1:-}" ;;
      --parallel) PARALLEL=true ;;
      --max-parallel) shift; MAX_PARALLEL="${1:-}" ;;
      --force) FORCE=true ;;
      --metadata) EMBED_METADATA=true ;;
      --artist) shift; ARTIST="${1:-}" ;;
      --copyright) shift; COPYRIGHT="${1:-}" ;;
      --keywords) shift; KEYWORDS="${1:-}" ;;
      --description) shift; DESCRIPTION="${1:-}" ;;
      --width) shift; WIDTH="${1:-1024}" ;;
      --height) shift; HEIGHT="${1:-1024}" ;;
      --negative-prompt) shift; NEGATIVE_PROMPT="${1:-}" ;;
      --output-format) shift; OUTPUT_FORMAT="${1:-text}" ;;
      --provider) shift; PROVIDER="${1:-}" ;;
      --model) shift; MODEL="${1:-}" ;;
      --models) shift; MODELS="${1:-}" ;;
      --google-credentials) shift; GOOGLE_CREDENTIALS="${1:-}" ;;
      --google-location) shift; GOOGLE_LOCATION="${1:-us-central1}" ;;
      --google-auth-method) shift; GOOGLE_AUTH_METHOD="${1:-auto}" ;;
      --no-generation-info) SAVE_GENERATION_INFO=false ;;
      --list-models) LIST_MODELS=true ;;
      --all-models) ALL_MODELS=true ;;
      --) shift; break ;;
      -*) die "Unknown option: $1" ;;
      *) die "Unexpected positional argument: $1" ;;
    esac
    shift
  done
}

list_models() {
  local all_models="${1:-false}"
  
  # Model data: provider|model_id|model_name|description|quality_tier|cost_per_image|limitations|native_format
  local models_data='
openai|dall-e-3|DALL-E 3|OpenAI latest image generation model|high|~$0.040|1024x1024 max, no negative prompt|png
openai|dall-e-2|DALL-E 2|OpenAI previous generation model|medium|~$0.020|512x512 max, lower quality|png
stability|stable-diffusion-xl-1024-v1-0|SDXL 1024|Legacy v1 engine, best quality|high|~$0.004|Legacy, 1024x1024 optimal|png
google|imagen-4.0-generate-001|Imagen 4 Standard|Google Imagen 4 standard generation|high|~$0.040|Vertex AI, service account or gcloud auth|png
google|imagen-4.0-ultra-generate-001|Imagen 4 Ultra|Google Imagen 4 ultra-high quality|high|~$0.080|Vertex AI, service account or gcloud auth|png
google|imagen-4.0-fast-generate-001|Imagen 4 Fast|Google Imagen 4 fast generation|medium|~$0.020|Vertex AI, service account or gcloud auth|png
google|imagen-3.0-generate-001|Imagen 3|Google Imagen 3 generation model|high|~$0.050|Vertex AI, service account or gcloud auth|png
huggingface|stabilityai/stable-diffusion-2-1|Stable Diffusion 2.1|Open source model via HF Inference|low|Free tier limited|Rate limited, slow|png
huggingface|runwayml/stable-diffusion-v1-5|Stable Diffusion 1.5|Older but reliable|low|Free tier limited|Rate limited|png
huggingface|black-forest-labs/flux-1.1-pro|FLUX 1.1 Pro|Via Hugging Face|high|~$0.010|Requires HF API key|webp
bfl|flux-1.1-pro|FLUX 1.1 Pro|Black Forest Labs flagship model|high|~$0.015|Fast, high quality|jpg
bfl|flux-1.0-pro|FLUX 1.0 Pro|Previous version|medium|~$0.010|Good quality|jpg
replicate|stability-ai/sdxl:39ed52f2a78e934b3ba6e2a89f5b1c712de7dfea535525255b1aa35c5565e08b|SDXL|Stability AI SDXL on Replicate|medium|~$0.005|Per-second billing|png
replicate|black-forest-labs/flux-1.1-pro|FLUX 1.1 Pro|BFL FLUX via Replicate|high|~$0.020|Per-second billing|webp
siliconflow|stabilityai/stable-diffusion-3-medium|SD3 Medium|SiliconFlow hosted SD3|high|~$0.003|Chinese provider|png
siliconflow|stabilityai/stable-diffusion-xl-1.0|SDXL 1.0|SiliconFlow hosted SDXL|medium|~$0.002|Chinese provider|png
'
  
  # Determine which providers have API keys
  local available_providers=()
  [[ -n "${OPENAI_API_KEY:-}" ]] && available_providers+=("openai")
  [[ -n "${STABILITY_API_KEY:-}" ]] && available_providers+=("stability")
  # Google supports multiple auth methods
  if [[ -n "${GOOGLE_CREDENTIALS:-}" && -f "${GOOGLE_CREDENTIALS:-}" ]] || \
     [[ -n "${GOOGLE_API_KEY:-}" && -n "${GOOGLE_PROJECT_ID:-}" ]] || \
     command -v gcloud >/dev/null 2>&1; then
    available_providers+=("google")
  fi
  [[ -n "${HF_API_KEY:-}" ]] && available_providers+=("huggingface")
  [[ -n "${BFL_API_KEY:-}" ]] && available_providers+=("bfl")
  [[ -n "${REPLICATE_API_TOKEN:-}" ]] && available_providers+=("replicate")
  [[ -n "${SILICONFLOW_API_KEY:-}" ]] && available_providers+=("siliconflow")
  
  # Filter models
  local filtered_data=""
  while IFS='|' read -r provider model_id model_name description quality cost limits native_fmt; do
    # Skip empty lines
    [[ -z "$provider" ]] && continue
    # Skip comment lines
    [[ "$provider" == \#* ]] && continue
    
    if [[ "$all_models" == "true" ]]; then
      filtered_data+="$provider|$model_id|$model_name|$description|$quality|$cost|$limits|$native_fmt"$'\n'
    else
      # Check if provider is available
      for avail in "${available_providers[@]}"; do
        if [[ "$avail" == "$provider" ]]; then
          filtered_data+="$provider|$model_id|$model_name|$description|$quality|$cost|$limits|$native_fmt"$'\n'
          break
        fi
      done
    fi
  done <<< "$models_data"
  
  # Output format
  if [[ "${OUTPUT_FORMAT:-text}" == "json" ]]; then
    # JSON output
    local json_output="["
    local first=true
    while IFS='|' read -r provider model_id model_name description quality cost limits native_fmt; do
      [[ -z "$provider" ]] && continue
      local is_configured=false
      for avail in "${available_providers[@]}"; do
        if [[ "$avail" == "$provider" ]]; then
          is_configured=true
          break
        fi
      done
      local configured_val
      if [[ "$all_models" == "true" ]]; then
        configured_val="$is_configured"
      else
        configured_val="true"
      fi
      [[ "$first" == "true" ]] && first=false || json_output+=","
      json_output+="$(_jq -n \
        --arg provider "$provider" \
        --arg model "$model_id" \
        --arg name "$model_name" \
        --arg description "$description" \
        --arg quality "$quality" \
        --arg cost "$cost" \
        --arg limitations "$limits" \
        --arg format "${native_fmt:-png}" \
        --argjson configured "$configured_val" \
        '{provider:$provider,model:$model,name:$name,description:$description,quality:$quality,cost:$cost,limitations:$limitations,format:$format,configured:$configured}')"
    done <<< "$filtered_data"
    json_output+="]"
    echo "$json_output"
  else
    # ASCII table output
    echo "Available AI Image Generation Models"
    echo "====================================="
    if [[ "$all_models" != "true" && ${#available_providers[@]} -eq 0 ]]; then
      echo "No API keys detected. Use --all-models to see all available models."
      echo "Set environment variables for providers to see their models."
    fi
    echo ""
    
    # Column widths
    local -r col_status=6 col_provider=12 col_model=40 col_fmt=4 col_quality=8 col_cost=15 col_desc=40

    # Helper: build separator line with + at intersections
    _repeat_char() { local -r ch="$1" n="$2"; printf '%*s' "$n" '' | tr ' ' "$ch"; }

    local separator
    if [[ "$all_models" == "true" ]]; then
      separator="$(_repeat_char '-' "$col_status")+$(_repeat_char '-' "$((col_provider + 2))")+$(_repeat_char '-' "$((col_model + 2))")+$(_repeat_char '-' "$((col_fmt + 2))")+$(_repeat_char '-' "$((col_quality + 2))")+$(_repeat_char '-' "$((col_cost + 2))")+$(_repeat_char '-' "$((col_desc + 2))")"
    else
      separator="$(_repeat_char '-' "$col_provider")+$(_repeat_char '-' "$((col_model + 2))")+$(_repeat_char '-' "$((col_fmt + 2))")+$(_repeat_char '-' "$((col_quality + 2))")+$(_repeat_char '-' "$((col_cost + 2))")+$(_repeat_char '-' "$((col_desc + 2))")"
    fi

    # Print table header
    if [[ "$all_models" == "true" ]]; then
      printf "%-${col_status}s | %-${col_provider}s | %-${col_model}s | %-${col_fmt}s | %-${col_quality}s | %-${col_cost}s | %-${col_desc}s\n" \
        "Status" "Provider" "Model ID" "Fmt" "Quality" "Cost" "Description"
    else
      printf "%-${col_provider}s | %-${col_model}s | %-${col_fmt}s | %-${col_quality}s | %-${col_cost}s | %-${col_desc}s\n" \
        "Provider" "Model ID" "Fmt" "Quality" "Cost" "Description"
    fi
    printf '%s\n' "$separator"
    
    while IFS='|' read -r provider model_id model_name description quality cost limits native_fmt; do
      [[ -z "$provider" ]] && continue
      # Truncate description if too long
      local short_desc="${description:0:${col_desc}}"
      [[ ${#description} -gt $col_desc ]] && short_desc="${description:0:$((col_desc - 2))}.."
      # Truncate model ID if too long
      local short_model_id="$model_id"
      if [[ ${#model_id} -gt $col_model ]]; then
        short_model_id="${model_id:0:$((col_model - 3))}..."
      fi
      # Truncate cost if too long
      local short_cost="${cost:0:${col_cost}}"
      [[ ${#cost} -gt $col_cost ]] && short_cost="${cost:0:$((col_cost - 2))}.."
      local fmt="${native_fmt:-png}"
      if [[ "$all_models" == "true" ]]; then
        local status_icon="[ ]"
        local is_configured
        is_configured=false
        for avail in "${available_providers[@]}"; do
          if [[ "$avail" == "$provider" ]]; then
            is_configured=true
            break
          fi
        done
        [[ "$is_configured" == "true" ]] && status_icon="[x]"
        printf " %-5s | %-${col_provider}s | %-${col_model}s | %-${col_fmt}s | %-${col_quality}s | %-${col_cost}s | %s\n" \
          "$status_icon" "$provider" "$short_model_id" "$fmt" "$quality" "$short_cost" "$short_desc"
      else
        printf "%-${col_provider}s | %-${col_model}s | %-${col_fmt}s | %-${col_quality}s | %-${col_cost}s | %s\n" \
          "$provider" "$short_model_id" "$fmt" "$quality" "$short_cost" "$short_desc"
      fi
    done <<< "$filtered_data"
    
    if [[ "$all_models" != "true" ]]; then
      echo ""
      echo "Available providers (with API keys): ${available_providers[*]:-none}"
      echo "Use --all-models to see all models across all providers."
    fi
  fi
  exit 0
}

# ============================================================================
# MAIN
# ============================================================================
main() {
  parse_args "$@"

  # Set defaults for optional variables to avoid nounset errors
  CONFIG_FILE="${CONFIG_FILE:-}"
  PARALLEL="${PARALLEL:-false}"
  FORCE="${FORCE:-false}"
  EMBED_METADATA="${EMBED_METADATA:-false}"
  MAX_PARALLEL="${MAX_PARALLEL:-}"
  ARTIST="${ARTIST:-}"
  COPYRIGHT="${COPYRIGHT:-}"
  KEYWORDS="${KEYWORDS:-}"
  DESCRIPTION="${DESCRIPTION:-}"
  OUTPUT_FORMAT="${OUTPUT_FORMAT:-text}"
  PROVIDER="${PROVIDER:-}"
  MODEL="${MODEL:-}"
  MODELS="${MODELS:-}"
  LIST_MODELS="${LIST_MODELS:-false}"
  ALL_MODELS="${ALL_MODELS:-false}"
  GOOGLE_CREDENTIALS="${GOOGLE_CREDENTIALS:-}"
  GOOGLE_LOCATION="${GOOGLE_LOCATION:-us-central1}"
  GOOGLE_AUTH_METHOD="${GOOGLE_AUTH_METHOD:-auto}"
  SAVE_GENERATION_INFO="${SAVE_GENERATION_INFO:-true}"

  # Create directory structure
  ensure_directories

  # Ensure required commands
  require_cmd curl

  # Load .env if exists
  load_dotenv

  if [[ "$LIST_MODELS" == "true" ]]; then
    list_models "$ALL_MODELS"
    exit 0
  fi

  # Automatic version check (silent, non-blocking)
  _check_version

  # Merge config
  local config
  config="$(merge_config)"

  # Extract values
  local prompt output quality parallel max_parallel force embed_metadata artist copyright keywords description width height negative_prompt output_format provider model models save_generation_info
  eval "$config"

  # Set OUTPUT_FORMAT consistently
  OUTPUT_FORMAT="$output_format"
  SAVE_GENERATION_INFO="$save_generation_info"

  # Auto-append native format extension if output has no recognized image extension
  if [[ -n "$output" ]]; then
    output="$(resolve_output_extension "$output" "$provider" "$model" "$quality")"
  fi

  # Check for batch mode: if config file has jobs array
  local is_batch=false
  if [[ -n "$CONFIG_FILE" ]]; then
    local yaml_content
    yaml_content="$(parse_yaml "$CONFIG_FILE")"
    if echo "$yaml_content" | _jq -e '.jobs' >/dev/null 2>&1; then
      is_batch=true
      log_info "Batch mode detected in $CONFIG_FILE"
    fi
  fi

  if [[ "$is_batch" == "true" ]]; then
    # Batch processing
    local yaml_content
    yaml_content="$(parse_yaml "$CONFIG_FILE")"
    local jobs
    jobs="$(echo "$yaml_content" | _jq '.jobs')"

    if [[ "$parallel" == "true" ]]; then
      process_batch_parallel "$jobs"
    else
      process_batch_sequential "$jobs"
    fi
    exit $?
  else
    # Single image generation
    # Validate config
    if ! validate_config "$prompt" "$output" "$quality" "$width" "$height"; then
      if [[ "$OUTPUT_FORMAT" == "json" ]]; then
        output_json_error "Validation failed" "$EXIT_INVALID_PARAMS"
      fi
      exit "$EXIT_INVALID_PARAMS"
    fi

    log_info "Configuration validated: prompt='$prompt', output='$output', quality='$quality', size=${width}x${height}"
    
    # Multiple models support
    if [[ -n "$models" ]]; then
      local model_list
      IFS=',' read -ra model_list <<< "$models"
      local results=()
      local success_count=0
      local failure_count=0
      
      for model_item in "${model_list[@]}"; do
        # Trim whitespace
        model_item="$(echo "$model_item" | xargs)"
        [[ -z "$model_item" ]] && continue
        
        # Generate output filename with model suffix
        local base="${output%.*}"
        local ext="${output##*.}"
        local model_output="${base}-${model_item}.${ext}"
        
        log_info "Generating image with model: $model_item"
        if generate_image "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$model_output" "$provider" "$model_item"; then
          results+=("SUCCESS: $model_output")
          (( success_count++ ))
        else
          local exit_code=$?
          results+=("FAILED ($exit_code): $model_item")
          (( failure_count++ ))
        fi
      done
      
      # Summary
      log_info "Multiple model generation completed: $success_count succeeded, $failure_count failed"
      if [[ "$OUTPUT_FORMAT" == "json" ]]; then
        local json_results
        json_results="$(printf '%s\n' "${results[@]}" | _jq -R -s 'split("\n")[:-1] | map(split(": ")) | map({status: .[0], output: .[1]})' 2>/dev/null)"
        echo "{\"status\":\"partial\",\"summary\": {\"total\": ${#model_list[@]}, \"success\": $success_count, \"failure\": $failure_count}, \"results\": $json_results}"
      else
        printf '%s\n' "${results[@]}"
      fi
      
      if (( failure_count > 0 )); then
        exit "$EXIT_BATCH_PARTIAL_FAILURE"
      fi
    else
      # Single model generation
      if generate_image "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$output" "$provider" "$model"; then
        log_info "Image generation completed successfully"
        if [[ "$OUTPUT_FORMAT" == "json" ]]; then
          echo "{\"status\":\"success\",\"output\":\"$output\"}"
        fi
      else
        local exit_code=$?
        log_err "Image generation failed"
        if [[ "$OUTPUT_FORMAT" == "json" ]]; then
          echo "{\"status\":\"error\",\"message\":\"Image generation failed\",\"exit_code\":$exit_code}"
        fi
        exit "$exit_code"
      fi
    fi
  fi
}

# Testable main guard
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
