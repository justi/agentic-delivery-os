# Load .env file if exists
load_dotenv() {
  local env_file="${CONFIG_DIR}/.env"
  if [[ -f "$env_file" ]]; then
    log_debug "Loading .env from $env_file"
    # Source only if file exists and is readable
    if ! source "$env_file" 2>/dev/null; then
      log_warn "Failed to load .env file: $env_file"
    fi
  fi
}

# Parse YAML config file using yq, fallback to simple key-value
parse_yaml() {
  local config_file="$1"
  if [[ ! -f "$config_file" ]]; then
    log_err "Config file not found: $config_file"
    return "$EXIT_CONFIG_ERROR"
  fi

  # Try yq first (preferred, supports nested YAML)
  if command -v yq >/dev/null 2>&1; then
    # Convert YAML to JSON and use jq to generate shell assignments
    local json_data
    json_data="$(_yq eval -o=json '.' "$config_file" 2>/dev/null)"
    if [[ -n "$json_data" ]] && command -v jq >/dev/null 2>&1; then
      # Use jq to output key=value pairs with shell escaping
      echo "$json_data" | _jq -r 'to_entries[] | "\(.key)=\(.value | @sh)"' 2>/dev/null
      return 0
    fi
  fi

  # Fallback: simple key-value parsing (no nested structures)
  log_warn "yq not available or failed, using simple key-value fallback"
  awk -F': ' '/^[[:space:]]*[^#[:space:]]+:/ {gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); print $1 "=" $2}' "$config_file" | while IFS='=' read -r key value; do
    printf '%s=%q\n' "$key" "$value"
  done
}

# Merge config with precedence: CLI > YAML > env > defaults
merge_config() {
  # Load defaults
  local prompt="${PROMPT:-}"
  local output="${OUTPUT:-}"
  local quality="${QUALITY:-high}"
  local config_file="${CONFIG_FILE:-}"
  local parallel="${PARALLEL:-false}"
  local max_parallel="${MAX_PARALLEL:-$(nproc 2>/dev/null || echo 4)}"
  local force="${FORCE:-false}"
  local embed_metadata="${EMBED_METADATA:-false}"
  local artist="${ARTIST:-}"
  local copyright="${COPYRIGHT:-}"
  local keywords="${KEYWORDS:-}"
  local description="${DESCRIPTION:-}"
  local width="${WIDTH:-1024}"
  local height="${HEIGHT:-1024}"
  local negative_prompt="${NEGATIVE_PROMPT:-}"
  local output_format="${OUTPUT_FORMAT:-text}"
  local provider="${PROVIDER:-}"
  local model="${MODEL:-}"
  local models="${MODELS:-}"
  local save_generation_info="${SAVE_GENERATION_INFO:-true}"

  # Parse YAML if provided
  if [[ -n "$config_file" ]]; then
    local yaml_data
    yaml_data="$(parse_yaml "$config_file")"
    if [[ $? -eq 0 ]]; then
      # Extract values from yaml_data (now safe shell assignments)
      eval "$yaml_data" 2>/dev/null || log_warn "Failed to parse YAML config"
    fi
  fi

  # CLI overrides (already parsed in parse_args)

  # Output merged config with shell-escaped values
  cat <<EOF
prompt=$(shell_escape "$prompt")
output=$(shell_escape "$output")
quality=$(shell_escape "$quality")
parallel=$(shell_escape "$parallel")
max_parallel=$(shell_escape "$max_parallel")
force=$(shell_escape "$force")
embed_metadata=$(shell_escape "$embed_metadata")
artist=$(shell_escape "$artist")
copyright=$(shell_escape "$copyright")
keywords=$(shell_escape "$keywords")
description=$(shell_escape "$description")
width=$(shell_escape "$width")
height=$(shell_escape "$height")
negative_prompt=$(shell_escape "$negative_prompt")
output_format=$(shell_escape "$output_format")
provider=$(shell_escape "$provider")
model=$(shell_escape "$model")
models=$(shell_escape "$models")
save_generation_info=$(shell_escape "$save_generation_info")
EOF
}

# Validate configuration
validate_config() {
  local prompt="$1"
  local output="$2"
  local quality="$3"
  local width="$4"
  local height="$5"

  # Prompt required and non-empty
  if [[ -z "$prompt" ]]; then
    log_err "Prompt is required"
    return "$EXIT_INVALID_PARAMS"
  fi

  # Output path required and writable
  if [[ -z "$output" ]]; then
    log_err "Output path is required"
    return "$EXIT_INVALID_PARAMS"
  fi
  local output_dir
  output_dir="$(dirname "$output")"
  if [[ ! -d "$output_dir" ]]; then
    log_err "Output directory does not exist: $output_dir"
    return "$EXIT_INVALID_PARAMS"
  fi
  if [[ ! -w "$output_dir" ]]; then
    log_err "Output directory not writable: $output_dir"
    return "$EXIT_INVALID_PARAMS"
  fi

  # Quality valid
  case "$quality" in
    high|medium|low) ;;
    *) log_err "Invalid quality: $quality"; return "$EXIT_INVALID_PARAMS" ;;
  esac

  # Dimensions within reasonable range (256-2048 for most providers)
  if ! [[ "$width" =~ ^[0-9]+$ ]] || (( width < 256 || width > 2048 )); then
    log_err "Width must be between 256 and 2048: $width"
    return "$EXIT_INVALID_PARAMS"
  fi
  if ! [[ "$height" =~ ^[0-9]+$ ]] || (( height < 256 || height > 2048 )); then
    log_err "Height must be between 256 and 2048: $height"
    return "$EXIT_INVALID_PARAMS"
  fi

  # Output format validation
  local ext="${output##*.}"
  ext="${ext,,}"
  local ext_normalized="$ext"
  [[ "$ext_normalized" == "jpeg" ]] && ext_normalized="jpg"

  case "$ext_normalized" in
    png|jpg|webp|avif)
      # Supported format — validate conversion feasibility if provider+model are known
      if [[ -n "${PROVIDER:-}" ]]; then
        local val_model="${MODEL:-}"
        if [[ -z "$val_model" ]]; then
          val_model="$(get_provider_model "$PROVIDER")"
        fi
        local native_fmt
        native_fmt="$(get_native_format "$PROVIDER" "$val_model")"
        if [[ "$native_fmt" != "$ext_normalized" ]]; then
          # Conversion will be needed — check if tools are available
          local converter
          converter="$(get_conversion_command "$native_fmt" "$ext_normalized")"
          if [[ -z "$converter" ]]; then
            # Build actionable error message
            local install_hint=""
            case "$ext_normalized" in
              webp) install_hint="Install cwebp: sudo apt install webp\n       Or install ImageMagick: sudo apt install imagemagick" ;;
              avif) install_hint="Install avifenc: sudo apt install libavif-apps\n       Or install ImageMagick: sudo apt install imagemagick" ;;
              png|jpg) install_hint="Install ImageMagick: sudo apt install imagemagick" ;;
            esac
            # Suggest alternative models that natively produce the requested format
            local alt_models=""
            case "$ext_normalized" in
              png) alt_models="dall-e-3, imagen-4.0-generate-001, stable-diffusion-xl-1024-v1-0" ;;
              jpg) alt_models="flux-1.1-pro (bfl), flux-1.0-pro (bfl)" ;;
              webp) alt_models="black-forest-labs/flux-1.1-pro (huggingface or replicate)" ;;
            esac
            printf >&2 "Error: Model '%s' natively produces %s images, but you requested %s output.\n" "$val_model" "${native_fmt^^}" "${ext_normalized^^}"
            printf >&2 "       Conversion requires a tool but none is installed.\n"
            printf >&2 "\n"
            printf >&2 "       Options:\n"
            printf >&2 "         1. %b\n" "$install_hint"
            printf >&2 "         2. Use the model's native format: --output image.%s\n" "$native_fmt"
            if [[ -n "$alt_models" ]]; then
              printf >&2 "         3. Choose a model that natively produces %s (e.g., %s)\n" "${ext_normalized^^}" "$alt_models"
            fi
            return "$EXIT_INVALID_PARAMS"
          else
            log_debug "validate_config: will convert $native_fmt -> $ext_normalized via $converter after download"
          fi
        fi
      fi
      ;;
    tiff|tif)
      log_warn "Output format .$ext may not be supported by all providers; PNG/JPG recommended for best compatibility"
      ;;
  esac

  return 0
}

