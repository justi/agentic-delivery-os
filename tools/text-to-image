  if [[ ! -f "$output_path" ]]; then
    _GEN_API_URL="https://api-inference.huggingface.co/models/$model"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
