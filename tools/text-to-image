  fi
  if [[ -z "$api_key" ]]; then
    log_debug "Replicate API key not set"
    return "$EXIT_AUTH_FAILED"
  fi

  local api_url payload
  if [[ "$model" == *:* ]]; then
    # Versioned community model: POST /v1/predictions with version hash
    local version_hash="${model##*:}"
    api_url="https://api.replicate.com/v1/predictions"
    payload="$(_jq -n --arg prompt "$prompt" --arg version "$version_hash" '{version: $version, input: {prompt: $prompt}}' 2>/dev/null)"
  else
    # Official model: POST /v1/models/{owner}/{name}/predictions without version
    api_url="https://api.replicate.com/v1/models/${model}/predictions"
    payload="$(_jq -n --arg prompt "$prompt" '{input: {prompt: $prompt}}' 2>/dev/null)"
  fi

  local response
  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would call: curl -s -X POST $api_url -H Authorization: Bearer $(sanitize_token "$api_key") -H Content-Type: application/json -d '$payload'"
    return "$EXIT_SUCCESS"
  fi
  response="$(retry_curl --max-time 60 -s -X POST "$api_url" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>/dev/null)"

  local exit_code=$?
  if (( exit_code != 0 )); then
    _GEN_API_URL="$api_url"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "Replicate API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  local prediction_id
  prediction_id="$(_jq -r '.id // empty' <<< "$response" 2>/dev/null)"
  if [[ -z "$prediction_id" ]]; then
    _GEN_API_URL="$api_url"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    log_err "No prediction_id in Replicate response"
    return "$EXIT_SERVER_ERROR"
  fi

  # Poll for result
  local max_polls=30
  local poll_count=0
  while (( poll_count < max_polls )); do
    sleep 2
    response="$(retry_curl --max-time 60 -s "https://api.replicate.com/v1/predictions/$prediction_id" \
      -H "Authorization: Bearer $api_key" 2>/dev/null)"
    local status
    status="$(_jq -r '.status // empty' <<< "$response" 2>/dev/null)"
    if [[ "$status" == "succeeded" ]]; then
      local url
      # Official models return output as string; community models as array
      url="$(_jq -r 'if (.output | type) == "array" then .output[0] // empty elif (.output | type) == "string" then .output // empty else empty end' <<< "$response" 2>/dev/null)"
      if [[ -n "$url" ]]; then
        _curl -s -o "$output_path" "$url"
        # Capture metadata for generation info sidecar
        _GEN_API_URL="$api_url"
        _GEN_API_REQUEST="$payload"
        _GEN_API_RESPONSE="$response"
        log_info "Image generated with Replicate ($model)"
        return "$EXIT_SUCCESS"
      fi
    elif [[ "$status" == "failed" ]]; then
      _GEN_API_URL="$api_url"
      _GEN_API_REQUEST="$payload"
      _GEN_API_RESPONSE="$response"
      _GEN_API_METHOD="POST"
      log_err "Replicate generation failed"
      return "$EXIT_SERVER_ERROR"
    fi
    (( poll_count++ ))
  done

  _GEN_API_URL="$api_url"
  _GEN_API_REQUEST="$payload"
  _GEN_API_RESPONSE="$response"
  _GEN_API_METHOD="POST"
  log_err "Replicate polling timeout"
  return "$EXIT_SERVER_ERROR"
}

