log_warn()  { printf '[WARN]  %s %s\n' "${LOG_TAG}" "$*" >&2; if [[ -n "$MAIN_LOG_FILE" ]]; then local ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; _jq -n --arg ts "$ts" --arg msg "$*" '{timestamp: $ts, level: "WARN", message: $msg}' >> "${MAIN_LOG_FILE}"; fi; if [[ -n "${JOB_LOG_FILE:-}" ]]; then local ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; _jq -n --arg ts "$ts" --arg msg "$*" '{timestamp: $ts, level: "WARN", message: $msg}' >> "${JOB_LOG_FILE}"; fi; }
log_err()   { printf '[ERROR] %s %s\n' "${LOG_TAG}" "$*" >&2; if [[ -n "$MAIN_LOG_FILE" ]]; then local ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; _jq -n --arg ts "$ts" --arg msg "$*" '{timestamp: $ts, level: "ERROR", message: $msg}' >> "${MAIN_LOG_FILE}"; fi; if [[ -n "${JOB_LOG_FILE:-}" ]]; then local ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; _jq -n --arg ts "$ts" --arg msg "$*" '{timestamp: $ts, level: "ERROR", message: $msg}' >> "${JOB_LOG_FILE}"; fi; }
log_debug() { [[ "${VERBOSE}" == "true" ]] && printf '[DEBUG] %s %s\n' "${LOG_TAG}" "$*" >&2; if [[ "${VERBOSE}" == "true" && -n "$MAIN_LOG_FILE" ]]; then local ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; _jq -n --arg ts "$ts" --arg msg "$*" '{timestamp: $ts, level: "DEBUG", message: $msg}' >> "${MAIN_LOG_FILE}"; fi; if [[ "${VERBOSE}" == "true" && -n "${JOB_LOG_FILE:-}" ]]; then local ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"; _jq -n --arg ts "$ts" --arg msg "$*" '{timestamp: $ts, level: "DEBUG", message: $msg}' >> "${JOB_LOG_FILE}"; fi; }
log_fatal() { 
  output_json_error "$@" "${EXIT_GENERAL_ERROR}"
  log_err "$@"; 
  exit "${EXIT_GENERAL_ERROR}"; 
}

# Output error in JSON format if requested
output_json_error() {
  local message="$1"
  local exit_code="${2:-1}"
  if [[ "${OUTPUT_FORMAT:-text}" == "json" ]]; then
    echo "{\"status\":\"error\",\"message\":\"$message\",\"exit_code\":$exit_code}" >&2
  fi
}

die() { 
  output_json_error "$@" "${EXIT_INVALID_PARAMS}"
  log_err "$@"; 
  exit "${EXIT_INVALID_PARAMS}"; 
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

run_cmd() {
  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would execute: $*"
    return 0
  fi
  "$@"
}

