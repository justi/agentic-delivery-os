# Provider selection
select_provider() {
  local quality="$1"
  local chain
  case "$quality" in
    high) chain="$QUALITY_HIGH" ;;
    medium) chain="$QUALITY_MEDIUM" ;;
    low) chain="$QUALITY_LOW" ;;
    *) return "$EXIT_INVALID_PARAMS" ;;
  esac

  local old_ifs="$IFS"
  IFS=' '
  for provider in $chain; do
    if [[ "${provider}" == "google" ]]; then
      # Google supports multiple auth methods: JSON credentials, gcloud, or API key
      if [[ -n "${GOOGLE_CREDENTIALS:-}" && -f "${GOOGLE_CREDENTIALS:-}" ]] || \
         command -v gcloud >/dev/null 2>&1 || \
         [[ -n "${GOOGLE_API_KEY:-}" && -n "${GOOGLE_PROJECT_ID:-}" ]]; then
        echo "$provider"
        IFS="$old_ifs"
        return 0
      fi
      continue
    fi
    local key_var="${provider^^}_API_KEY"
    if [[ "${provider}" == "replicate" ]]; then
      key_var="REPLICATE_API_TOKEN"
    fi
    if [[ -n "${!key_var:-}" ]]; then
      echo "$provider"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"

  log_err "No available provider for quality $quality"
  return "$EXIT_AUTH_FAILED"
}

# Get model used by provider
get_provider_model() {
  local provider="$1"
  case "$provider" in
    openai) echo "dall-e-3" ;;
    stability) echo "stable-diffusion-xl-1024-v1-0" ;;
    google) echo "imagen-4.0-generate-001" ;;
    huggingface) echo "${HF_MODEL:-stabilityai/stable-diffusion-2-1}" ;;
    bfl) echo "flux-1.1-pro" ;;
    replicate) echo "${REPLICATE_MODEL:-stability-ai/sdxl:39ed52f2a78e934b3ba6e2a89f5b1c712de7dfea535525255b1aa35c5565e08b}" ;;
    siliconflow) echo "stabilityai/stable-diffusion-3-medium" ;;
    *) echo "unknown" ;;
  esac
}

# Main image generation function
generate_image() {
  local prompt="$1"
  local negative_prompt="$2"
  local width="$3"
  local height="$4"
  local quality="$5"
  local output_path="$6"
  local provider="$7"
  local model="$8"

  # Determine provider if not provided
  if [[ -z "$provider" ]]; then
    provider="$(select_provider "$quality")"
    local exit_code=$?
    if (( exit_code != 0 )); then
      return "$exit_code"
    fi
  else
    # Validate provider
    case "$provider" in
      openai|stability|google|huggingface|bfl|replicate|siliconflow) ;;
      *) log_err "Invalid provider: $provider"; return "$EXIT_INVALID_PARAMS" ;;
    esac
  fi

  log_info "Using provider: $provider"

  # Determine model if not provided
  if [[ -z "$model" ]]; then
    model="$(get_provider_model "$provider")"
  fi

  # Compute cache key (include model)
  local cache_key
  cache_key="$(compute_cache_key "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$provider" "$model")"

  # Check cache unless force is set
  if [[ "${FORCE}" != "true" ]]; then
    if cache_lookup "$cache_key" "$output_path"; then
      # If YAML sidecar was not restored from cache, generate a basic one
      if [[ "${SAVE_GENERATION_INFO}" == "true" ]]; then
        local output_yaml="${output_path%.*}.yaml"
        if [[ ! -f "$output_yaml" ]]; then
          write_generation_info "$output_path" "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$provider" "$model" 0
          # Back-fill cache with the newly created YAML
          local cache_file="${CACHE_DIR}/${cache_key}"
          if [[ -f "$output_yaml" ]]; then
            cp "$output_yaml" "${cache_file}.yaml" 2>/dev/null || true
          fi
        fi
      fi
      return "$EXIT_SUCCESS"
    fi
  fi

  # Clear metadata capture
  _GEN_API_URL=""
  _GEN_API_METHOD="POST"
  _GEN_API_REQUEST=""
  _GEN_API_RESPONSE=""
  _GEN_HTTP_CODE=""
  _GEN_EXTRA_INFO=""

  local gen_start_ms
  gen_start_ms="$(date +%s%3N)"

  # Generate image
  "generate_image_$provider" "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$output_path" "$model"
  local exit_code=$?

  local gen_end_ms
  gen_end_ms="$(date +%s%3N)"
  local gen_duration_ms=$(( gen_end_ms - gen_start_ms ))

  if (( exit_code == EXIT_AUTH_FAILED )); then
    provider_not_configured_error "$provider"
    return "$exit_code"
  fi

  if [[ "${DRY_RUN}" == "true" ]]; then
    return "$exit_code"
  fi

  if (( exit_code == 0 )); then
    # Ensure output format matches requested extension (e.g., convert WebP -> PNG)
    ensure_output_format "$output_path" || true
  fi

  # Write generation info sidecar YAML (on BOTH success and error)
  if [[ "${SAVE_GENERATION_INFO}" == "true" ]]; then
    write_generation_info "$output_path" "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$provider" "$model" "$gen_duration_ms" "$exit_code"
  fi

  if (( exit_code != 0 )); then
    return "$exit_code"
  fi

  # Store in cache (success only)
  cache_store "$cache_key" "$output_path" "$prompt" "$negative_prompt" "$width" "$height" "$quality" "$provider" "$model"

  # Embed metadata if requested
  if [[ "${EMBED_METADATA}" == "true" ]]; then
    embed_metadata "$output_path" "${ARTIST}" "${COPYRIGHT}" "${KEYWORDS}" "${DESCRIPTION}" "$prompt" "$provider"
  fi

  # Optional cache cleanup
  cache_cleanup

  return "$EXIT_SUCCESS"
}

ensure_directories() {
  CONFIG_DIR="${TEXT_TO_IMAGE_CONFIG_DIR:-${HOME}/.ai/text-to-image}"
  CACHE_DIR="${CONFIG_DIR}/cache"
  LOG_DIR="${CONFIG_DIR}/logs"
  JOB_LOG_DIR="${LOG_DIR}/jobs"
  MAIN_LOG_FILE="${LOG_DIR}/main.log"
  mkdir -p "${CACHE_DIR}" "${LOG_DIR}" "${JOB_LOG_DIR}"
  # Set restrictive permissions (owner only)
  chmod 700 "${CONFIG_DIR}" "${CACHE_DIR}" "${LOG_DIR}" "${JOB_LOG_DIR}"
}

# OpenAI DALL-E provider
generate_image_openai() {
  local prompt="$1"
  local negative_prompt="$2"  # Not supported
  local width="$3"
  local height="$4"
  local quality="$5"  # Not used
  local output_path="$6"
  local model="${7:-dall-e-3}"

  local api_key="${OPENAI_API_KEY:-}"
  if [[ -z "$api_key" ]]; then
    log_debug "OpenAI API key not set"
    return "$EXIT_AUTH_FAILED"
  fi

  # Validate model
  case "$model" in
    dall-e-2|dall-e-3) ;;
    *) log_err "Unsupported OpenAI model: $model. Supported: dall-e-2, dall-e-3"; return "$EXIT_INVALID_PARAMS" ;;
  esac

  local size="${width}x${height}"
  local payload
  payload="$(_jq -n --arg prompt "$prompt" --arg size "$size" --arg model "$model" '{prompt: $prompt, model: $model, size: $size, response_format: "url"}' 2>/dev/null)"

  if [[ "${DRY_RUN}" == "true" ]]; then
    log_info "[DRY-RUN] Would call: curl -s -X POST https://api.openai.com/v1/images/generations -H Authorization: Bearer $(sanitize_token "$api_key") -H Content-Type: application/json -d '$payload'"
    return "$EXIT_SUCCESS"
  fi

  response="$(retry_curl --max-time 60 -s -X POST "https://api.openai.com/v1/images/generations" \
    -H "Authorization: Bearer $api_key" \
    -H "Content-Type: application/json" \
    -d "$payload")"

  local exit_code=$?
  if (( exit_code != 0 )); then
    _GEN_API_URL="https://api.openai.com/v1/images/generations"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    local api_error
    api_error="$(extract_api_error "$response" 2>/dev/null)"
    log_err "OpenAI API call failed: ${api_error:-unknown error}"
    log_debug "Full response: ${response:0:500}"
    return "$exit_code"
  fi

  local url
  url="$(_jq -r '.data[0].url // empty' <<< "$response" 2>/dev/null)"
  if [[ -z "$url" ]]; then
    _GEN_API_URL="https://api.openai.com/v1/images/generations"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    log_err "No URL in OpenAI response"
    return "$EXIT_SERVER_ERROR"
  fi

  if ! _curl -s -o "$output_path" "$url"; then
    _GEN_API_URL="https://api.openai.com/v1/images/generations"
    _GEN_API_REQUEST="$payload"
    _GEN_API_RESPONSE="$response"
    _GEN_API_METHOD="POST"
    log_err "Failed to download image from $url"
    return "$EXIT_NETWORK_ERROR"
  fi

  # Capture metadata for generation info sidecar
  _GEN_API_URL="https://api.openai.com/v1/images/generations"
  _GEN_API_REQUEST="$payload"
  _GEN_API_RESPONSE="$response"
  local revised_prompt
  revised_prompt="$(_jq -r '.data[0].revised_prompt // empty' <<< "$response" 2>/dev/null)"
  if [[ -n "$revised_prompt" ]]; then
    _GEN_EXTRA_INFO="revised_prompt=${revised_prompt}"
  fi

  log_info "Image generated with OpenAI ($model)"
  return "$EXIT_SUCCESS"
}

